# ── Email delivery for website messages ────────────────────────────────
# The Contact form, Careers applications, and lead capture all send you an
# email via Gmail/Google Workspace SMTP (nodemailer).
#
# GMAIL_USER          The mailbox that SENDS the notifications (e.g. your
#                     Google Workspace info@hitroo.com, or any Gmail).
# GMAIL_APP_PASSWORD  A Google "App Password" — NOT your normal password.
#                     Create at: Google Account → Security → 2-Step
#                     Verification → App passwords.
GMAIL_USER=info@hitroo.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Where website messages are delivered. Defaults to info@hitroo.com if unset.
LEAD_EMAIL_RECIPIENT=info@hitroo.com

# ── Admin content manager (/admin) ─────────────────────────────────────
ADMIN_PASSWORD=change-me

# ── Optional: legacy AI chat route (not used by the current UI) ─────────
GROQ_API_KEY=
